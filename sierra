            -- 1. Desactivamos colisiones de las partes
            for _, part in pairs(Char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
            
            -- 2. 🧠 EL SECRETO: Forzamos al Humanoid a estar en estado NoClip
            local Hum = Char:FindFirstChild("Humanoid")
            if Hum then
                -- Esto evita que Roblox te empuje hacia afuera de las paredes
                Hum:ChangeState(Enum.HumanoidStateType.NoClip)
            end
        end
    end
end)







