-- MOTOR TRIGGER BOT V15.1 (Z-SQUAD 3D PARALLEL GRID - FIX DEFINITIVO CÁMARA MÓVIL)
task.spawn(function()
    local Players = game:GetService("Players")
    local Camera = workspace.CurrentCamera
    local LP = Players.LocalPlayer
    local VIM = game:GetService("VirtualInputManager")
    local UserInputService = game:GetService("UserInputService")
    
    local isMobile = UserInputService.TouchEnabled 

    while task.wait() do 
        if _G.TriggerBotEnabled then
            local hitEnemy = false

            -- 🔥 5 Rayos 3D directos de la cámara (Nunca se duermen)
            local camCFrame = Camera.CFrame
            local up = camCFrame.UpVector * 0.3    
            local right = camCFrame.RightVector * 0.3 
            
            local origins = {
                camCFrame.Position,               
                camCFrame.Position + up,          
                camCFrame.Position - up,          
                camCFrame.Position + right,       
                camCFrame.Position - right        
            }
            
            local rayDirection = camCFrame.LookVector * 10000 
            
            local rayParams = RaycastParams.new()
            rayParams.IgnoreWater = true

            if _G.TriggerWallCheck then
                rayParams.FilterDescendantsInstances = {LP.Character, Camera}
                rayParams.FilterType = Enum.RaycastFilterType.Exclude
            else
                local enemyTargets = {}
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LP and p.Character then
                        if _G.TriggerTeamCheck and p.Team == LP.Team then
                            -- Ignorar compas
                        else
                            table.insert(enemyTargets, p.Character)
                        end
                    end
                end
                rayParams.FilterDescendantsInstances = enemyTargets
                rayParams.FilterType = Enum.RaycastFilterType.Include
            end

            for _, origin in ipairs(origins) do
                local hit = workspace:Raycast(origin, rayDirection, rayParams)

                if hit and hit.Instance then
                    local currentObj = hit.Instance
                    local Hum = nil
                    local targetCharacter = nil

                    while currentObj and currentObj ~= workspace do
                        Hum = currentObj:FindFirstChild("Humanoid")
                        if Hum then
                            targetCharacter = currentObj
                            break
                        end
                        currentObj = currentObj.Parent
                    end
                    
                    if Hum and targetCharacter then
                        local isEnemy = true
                        if _G.TriggerTeamCheck then
                            local targetPlayer = Players:GetPlayerFromCharacter(targetCharacter)
                            if targetPlayer and targetPlayer.Team == LP.Team then
                                isEnemy = false
                            end
                        end

                        if Hum.Health > 0 and targetCharacter ~= LP.Character and isEnemy then
                            hitEnemy = true
                            break 
                        end
                    end
                end
            end

            -- 🔥 EL CEREBRO DE LA RÁFAGA (AUTO-CLICKER ANTI-BUG) 🔥
            if hitEnemy then
                local delayMap = {["1"] = 0.2, ["2"] = 0.1, ["3"] = 0.05, ["4"] = 0.01, ["5 (Fluido / Dejar Apretado)"] = 0}
                local waitTime = delayMap[_G.TriggerLevel] or 0
                
                if isMobile then
                    local W = Camera.ViewportSize.X
                    local H = Camera.ViewportSize.Y
                    
                    -- 1. APRIETA LOS 3 PUNTOS
                    VIM:SendTouchEvent(11, 0, W * 0.80, H * 0.65)
                    VIM:SendTouchEvent(12, 0, W * 0.85, H * 0.75)
                    VIM:SendTouchEvent(13, 0, W * 0.75, H * 0.75)
                    
                    task.wait(0.01) -- Micro-pulso para que registre la bala
                    
                    -- 2. SUELTA INSTANTÁNEAMENTE (Libera la cámara para que no se congele)
                    VIM:SendTouchEvent(11, 2, W * 0.80, H * 0.65)
                    VIM:SendTouchEvent(12, 2, W * 0.85, H * 0.75)
                    VIM:SendTouchEvent(13, 2, W * 0.75, H * 0.75)
                    
                    if waitTime > 0 then task.wait(waitTime) end
                else
                    -- MODO PC
                    if mouse1press then 
                        pcall(mouse1press) 
                        task.wait(0.01)
                        pcall(mouse1release)
                        if waitTime > 0 then task.wait(waitTime) end
                    else 
                        VIM:SendMouseButtonEvent(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2, 0, true, game, 1)
                        task.wait(0.01)
                        VIM:SendMouseButtonEvent(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2, 0, false, game, 1)
                        if waitTime > 0 then task.wait(waitTime) end
                    end
                end
            end
        end
    end
end)


























