local ProcessedAutoEnemies = {}
local SkyBase = nil
local OriginalCFrame = nil 

local SectionAuto = TabCombat:CreateSection("-- Tp Kill v2 / Auto Beta v1.0 🚁 --")

TabCombat:CreateToggle({
   Name = "Tp Kill Auto (🔥)",
   CurrentValue = false,
   Callback = function(Value) 
      _G.AutoWipe_Enabled = Value 
      local LP = game:GetService("Players").LocalPlayer
      local char = LP.Character
      local root = char and char:FindFirstChild("HumanoidRootPart")
      local hum = char and char:FindFirstChild("Humanoid")
      
      if Value then
          if root then OriginalCFrame = root.CFrame end

          if not SkyBase then
              SkyBase = Instance.new("Part")
              SkyBase.Size = Vector3.new(100, 2, 100)
              SkyBase.Position = Vector3.new(50000, 50000, 50000) 
              SkyBase.Anchored = true
              SkyBase.Transparency = 0.7 
              SkyBase.Material = Enum.Material.Glass
              SkyBase.Color = Color3.fromRGB(255, 0, 0) 
              SkyBase.Parent = workspace
          end
          
          if root then
              root.CFrame = CFrame.new(50000, 50005, 50000)
              task.wait(0.1)
              root.Anchored = true 
          end
      else
          -- 🔥 FIX MÓVIL SÚPER AGRESIVO: RESTAURAR FÍSICAS Y BOTONES AL INSTANTE 🔥
          if root and OriginalCFrame then 
              root.Anchored = false 
              
              -- 1. Lo bajamos y matamos toda la inercia
              root.CFrame = OriginalCFrame
              root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
              root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
              
              task.wait(0.05) 
          end
          
          if hum then
              -- 2. Quitamos el estado de "derribado"
              hum.PlatformStand = false 
              
              -- 3. Engañamos al celular para que devuelva el Joystick
              hum:ChangeState(Enum.HumanoidStateType.Freefall)
              task.wait(0.01)
              hum:ChangeState(Enum.HumanoidStateType.Landed)
              
              -- 4. Refrescamos estadísticas para que aparezca el botón de salto
              local oldJump = hum.JumpPower
              hum.JumpPower = 0
              task.wait(0.01)
              hum.JumpPower = oldJump
          end
          
          -- 5. Forzamos actualización de la cámara
          workspace.CurrentCamera.CameraSubject = hum

          if SkyBase then SkyBase:Destroy() SkyBase = nil end
          table.clear(ProcessedAutoEnemies)
          _G.EnemiesInBunker = false
      end
   end,
})

