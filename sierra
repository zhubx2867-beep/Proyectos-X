    local Tracer_Data = {}

    local function CreateTracer(player)
        if Tracer_Data[player] then return end
        
        local line = Instance.new("Frame")
        line.Name = "TracerLine"
        line.AnchorPoint = Vector2.new(0.5, 0.5) 
        line.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        line.BorderSizePixel = 0
        line.Visible = false
        line.Parent = TracerGui

        Tracer_Data[player] = line
    end

    local function RemoveTracer(player)
        if Tracer_Data[player] then
            Tracer_Data[player]:Destroy()
            Tracer_Data[player] = nil
        end
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP then CreateTracer(p) end
    end
    Players.PlayerAdded:Connect(function(p)
        if p ~= LP then CreateTracer(p) end
    end)
    Players.PlayerRemoving:Connect(RemoveTracer)

    RunService.RenderStepped:Connect(function()
        local ViewportSize = Camera.ViewportSize
        
        -- Calculamos el origen solo una vez por frame (Menos Lag)
        local Origin = Vector2.new(ViewportSize.X / 2, ViewportSize.Y)
        if _G.TracerOrigin == "Arriba" then
            Origin = Vector2.new(ViewportSize.X / 2, 0)
        elseif _G.TracerOrigin == "Centro" then
            Origin = Vector2.new(ViewportSize.X / 2, ViewportSize.Y / 2)
        end

        for player, line in pairs(Tracer_Data) do
            if not _G.TracersEnabled then
                line.Visible = false
                continue
            end

            local char = player.Character
            if char and char:FindFirstChild("Head") and char:FindFirstChild("Humanoid") then
                local head = char.Head
                local hum = char.Humanoid

                if hum.Health > 0 then
                    local headPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                    local Target

                    if onScreen then
                        -- Si está en pantalla (Enfrente), apuntamos a su cabeza
                        Target = Vector2.new(headPos.X, headPos.Y)
                    else
                        -- 🛠️ MAGIA Z-SQUAD 360°: Si está atrás, apuntamos a los bordes
                        local centerScreen = Vector2.new(ViewportSize.X / 2, ViewportSize.Y / 2)
                        
                        -- Ajuste de coordenadas para los que están atrás (Z negativo)
                        local fakePos = Vector2.new(headPos.X, headPos.Y)
                        if headPos.Z < 0 then
                            -- Invertir X y Y para que no cruce raro la pantalla
                            fakePos = Vector2.new(
                                centerScreen.X + (centerScreen.X - headPos.X), 
                                centerScreen.Y + (centerScreen.Y - headPos.Y)
                            )
                        end
                        
                        -- Dirección desde el centro hacia donde está el wey
                        local direction = (fakePos - centerScreen).Unit
                        
                        -- Mandamos el Target hasta el borde de tu pantalla (Efecto Radar)
                        Target = centerScreen + (direction * (ViewportSize.X * 1.5))
                    end
                    
                    -- 🧠 MATEMÁTICAS: Distancia, Centro y Rotación
                    local Distance = (Target - Origin).Magnitude
                    local Center = (Target + Origin) / 2
                    local Angle = math.atan2(Target.Y - Origin.Y, Target.X - Origin.X)

                    -- Dibujamos la línea
                    line.Size = UDim2.new(0, Distance, 0, 1.5) 
                    line.Position = UDim2.new(0, Center.X, 0, Center.Y)
                    line.Rotation = math.deg(Angle)
                    
                    -- Color dinámico
                    local hpPercent = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                    line.BackgroundColor3 = Color3.fromHSV(hpPercent * 0.3, 1, 1)

                    line.Visible = true
                else
                    line.Visible = false 
                end
            else
                line.Visible = false
            end
        end
    end)
end)























